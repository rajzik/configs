{
  "name": "@rajzik/configs-shared",
  "version": "4.0.1",
  "description": "Shared functionality for personal configs.",
  "keywords": [
    "config",
    "configs",
    "ignore-patterns",
    "shared",
    "tooling"
  ],
  "homepage": "https://github.com/rajzik/configs/tree/main/packages/shared",
  "bugs": {
    "url": "https://github.com/rajzik/configs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajzik/configs.git",
    "directory": "packages/shared"
  },
  "license": "MIT",
  "author": "Jan Šilhan <silhanu@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    },
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache dist dts .turbo node_modules",
    "format": "oxfmt --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware --type-check",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@rajzik/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^21.2.0 || ^20.11.0 || >=22.16.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
