{
  "name": "@rajzik/prettier-config",
  "version": "4.0.2",
  "description": "Reusable Prettier config for personal projects",
  "keywords": [
    "config",
    "formatter",
    "prettier",
    "prettier-config",
    "sharable",
    "tailwindcss"
  ],
  "homepage": "https://github.com/rajzik/configs/tree/main/packages/prettier-preset",
  "bugs": {
    "url": "https://github.com/rajzik/configs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajzik/configs.git",
    "directory": "packages/prettier-preset"
  },
  "license": "MIT",
  "author": "Jan Šilhan <silhanu@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache dist dts .turbo node_modules",
    "format": "oxfmt --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware --type-check",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "@rajzik/oxfmt-config": "workspace:*",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@rajzik/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "prettier-plugin-tailwindcss": "^0.6.14 || ^0.7.0"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-tailwindcss": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
