{
  "name": "@rajzik/danger-configuration",
  "version": "4.0.0",
  "description": "Reusable Danger.js scripts",
  "keywords": [
    "config",
    "danger",
    "lumos",
    "scripts"
  ],
  "homepage": "https://github.com/rajzik/configs/tree/main/packages/config-danger",
  "license": "MIT",
  "author": "Jan Šilhan <silhanu@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajzik/configs.git",
    "directory": "packages/config-danger"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    },
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache dist dts .turbo node_modules",
    "format": "oxfmt --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware --type-check"
  },
  "dependencies": {
    "danger": "13.0.7"
  },
  "devDependencies": {
    "@rajzik/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^21.2.0 || ^20.11.0 || >=22.16.0"
  }
}
