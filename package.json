{
  "name": "configs-root",
  "version": "0.0.0",
  "private": true,
  "description": "personal sharable configs",
  "keywords": [
    "config",
    "danger",
    "formatter",
    "lint",
    "oxfmt",
    "oxlint",
    "prettier",
    "tsconfig",
    "typescript"
  ],
  "homepage": "https://github.com/rajzik/configs",
  "bugs": {
    "url": "https://github.com/rajzik/configs/issues"
  },
  "license": "MIT",
  "author": "Jan Šilhan <silhanu@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajzik/configs.git"
  },
  "workspaces": [
    "./packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:beta": "changeset pre enter beta",
    "changeset:canary": "changeset pre enter canary",
    "clean": "git clean -xdf .cache dist dts .turbo node_modules",
    "clean:workspaces": "turbo run clean",
    "create-changeset": "pnpm dlx changeset",
    "format": "turbo run format --continue",
    "format:fix": "turbo run format --continue -- --write",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint --continue -- --fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "prepare": "pnpm build",
    "release": "changeset publish",
    "release:canary": "changeset publish --snapshot --no-git-tag --tag canary",
    "test": "turbo run test",
    "test:all": "pnpm run lint:ws && turbo run test lint format typecheck --continue",
    "test:fix": "turbo run test -- -u",
    "typecheck": "turbo run typecheck",
    "version": "changeset version",
    "version:canary": "changeset version --snapshot canary"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "0.8.0",
    "@changesets/get-release-plan": "4.0.16",
    "@changesets/types": "6.1.0",
    "@commitlint/cli": "20.5.0",
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "@rajzik/danger-configuration": "workspace:*",
    "@rajzik/oxlint-config": "workspace:*",
    "@rajzik/prettier-config": "workspace:*",
    "@rajzik/tsconfig": "workspace:*",
    "cross-env": "10.1.0",
    "danger": "13.0.7",
    "eslint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.2"
}
