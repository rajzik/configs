{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "SYSTEM_TASKDEFINITIONSURI",
    "NODE_ENV",
    "PWD"
  ],
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "lib/**", "dts/**"]
    },
    "format": {
      "cache": false,
      "outputLogs": "new-only"
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^topo"],
      "outputs": [".cache/.eslintcache"]
    },
    "test": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": [".cache/tsbuildinfo.json"]
    }
  }
}
